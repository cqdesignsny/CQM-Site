# Copy this file to .env.local and fill in values for local development.
# Never commit real secrets or credentials.

# Booking / Scheduling
NEXT_PUBLIC_CALENDLY_URL=

# Analytics (optional until scripts are wired in components/analytics.tsx)
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_TIKTOK_PIXEL_ID=
NEXT_PUBLIC_LINKEDIN_PARTNER_ID=

# Notion — CRM / Database (replaces Supabase)
NOTION_API_KEY=
NOTION_LEADS_DATABASE_ID=
NOTION_LEADS_DATASOURCE_ID=

# Resend — Transactional Email
RESEND_API_KEY=

# Resend — Newsletter Audience ID (find in Resend dashboard under Audiences)
RESEND_AUDIENCE_ID=

# Default email for proposal notifications (fallback)
DEFAULT_PROPOSAL_EMAIL=cesar@creativequalitymarketing.com

# Slack — Incoming Webhook for lead notifications
SLACK_WEBHOOK_URL=
